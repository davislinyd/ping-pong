{
  "name": "ping-pong-intranet-speedtest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A single-node intranet network speed test website.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,ui \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:api": "NODE_ENV=development tsx watch src/server/main.ts",
    "dev:ui": "vite --host 0.0.0.0",
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "start": "NODE_ENV=production node dist/server/main.js",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.2.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "jsdom": "^27.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.13"
  }
}
